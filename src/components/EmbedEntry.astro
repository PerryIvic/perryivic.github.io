---
import { Image } from 'astro:assets';

interface Props {
    image: ImageMetadata;
    alt: string;
    embeddedLink: string;
    embedSide?: "left" | "right";
}

const {
    image,
    alt,
    embeddedLink,
    embedSide = "left"
} = Astro.props;
---

<style>
.embed-entry {
    display: flex;
    align-items: center;
    justify-content: center;

    gap: 3rem;

    width: min(1400px, 90%);
    
    margin: 4rem auto;
}

.reverse {
    flex-direction: row-reverse;
}

.embed {
    flex: 0 0 600px;
    height: auto;
}

.embed iframe {
    width: 100%;
    height: 167px;

    border: 1px solid #000;
    border-radius: 6px;

    display: block;
    background: #363636;
}

.content {
    flex: 1;
}

.content :global(h2) {
    margin-top: 0;
    font-family: Verdana;
}

.content :global(p) {
    line-height: 1.7;
    font-family: Arial;
}
</style>

<section class:list={["embed-entry", embedSide === "right" && "reverse"]}>
    <div class="embed">
        <Image 
          src={image} 
          alt="{alt]"
        />
        <iframe
            src={embeddedLink}
            allowfullscreen
        />
    </div>

    <div class="content">
        <slot />
    </div>
</section>


