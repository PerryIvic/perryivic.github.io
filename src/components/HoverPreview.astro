---
import { Image } from "astro:assets";
import type { ProjectData } from "../types/project-data";

interface Props {
    project: ProjectData;
}

const { project } = Astro.props;
---

<style>
.hover-preview {
    position: relative;
    width: 100%;
    height: 100%;
}

.preview,
.preview-video {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: inherit;
}

.preview-video {
    position: absolute;
    inset: 0;

    object-fit: inherit;

    opacity: 0;
    transition: opacity .2s ease;
}
</style>

<div class="hover-preview">
    <Image
        src={project.image}
        alt={project.title}
        class="preview"
        style={`object-fit:${project.objectFit};`}
    />

    {project.video && (
        <video
            class="preview-video"
            muted
            loop
            playsinline
            preload="metadata"
            style={`object-fit:${project.objectFit};`}
        >
            <source src={project.video} type="video/webm" />
        </video>
    )}
</div>

<script>
document.querySelectorAll(".hover-preview").forEach((container) => {
    console.log("HoverPreview");
    const video = container.querySelector("video");
    if (!video) return;

    const image = container.querySelector("img");
    if(!image) return;

    container.addEventListener("mouseenter", () => {
        console.log("HoverPreview enter");
        video.currentTime = 0;
        video.play();

        image.style.opacity = "0";
        video.style.opacity = "1";
    });

    container.addEventListener("mouseleave", () => {
        console.log("HoverPreview leave");
        video.pause();
        video.currentTime = 0;

        image.style.opacity = "1";
        video.style.opacity = "0";
    });
});
</script>

