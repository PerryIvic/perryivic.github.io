---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/archive", label: "Archive" },
  { href: "/about", label: "About" }
];
---

<style>
  .nav-list {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 10;
    padding: 0;
  }

  .nav-list a {
    font-family: Verdana;
    text-decoration: none;
    color: inherit;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-list a:hover {
     color: #66A819;
  }

  .nav-list a.active {
    color: #66A819;
}
</style>

<nav>
  <ul class="nav-list">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          class={currentPath === link.href ? "active" : ""}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>