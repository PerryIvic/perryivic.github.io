---
interface Props {
    id: string;
    title: string;
}

const { id, title } = Astro.props;
---
<style>
.youtube-iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
} 
</style>

<iframe
    class="youtube-iframe"
    src={`https://www.youtube.com/embed/${id}`}
    title={title}
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen
/>