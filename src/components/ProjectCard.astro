---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { ProjectData } from "../types/project-data";
import HoverPreview from "./HoverPreview.astro";

interface Props {
    project: ProjectData;
}

const { project } = Astro.props;
---
<style>
.card {
    width: 100%;
    text-decoration: none;
    color: inherit;
    overflow: hidden;

    transition: transform .2s ease, border-color .2s ease;
}

.card:hover {
    transform: scale(1.05);
}

.card-image-container {
    height: 500px;
    width: 100%;

    display: flex;
    justify-content: center;
    align-items: center;

    background: black;
    overflow: hidden;
}

.card-image {
    width: 100%;
    height: 100%;

    background: black;
    display: block;
    border-radius: 12px;
}
</style>

<a href={project.href} class="card">
    <div class="card-image-container">
        <HoverPreview
            project={project}
        />
    </div>
</a>

