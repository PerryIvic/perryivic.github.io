---
import '../../styles/global.css';
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntryBorder from "../../components/EntryBorder.astro";
import ProjectGrid from "../../components/ProjectGrid.astro";
import { projects2x2 } from "../../project-data/tga-projects-2x2.ts";
import { projects3x3 } from "../../project-data/tga-projects-3x3.ts";
import { specializations } from "../../project-data/tga-specialization.ts"

const pageTitle = "Home";
const tgaTitle = "TGA Projects";
const specializationTitle =" Specialization Project";
---

<BaseLayout pageTitle={pageTitle}>
    <h1 class="header-project">{tgaTitle}</h1>
    <ProjectGrid projects={projects2x2} columns={2}/>
    <ProjectGrid projects={projects3x3} columns={3}/>

    <EntryBorder/>

    <h1 class="header-project">{specializationTitle}</h1>
    <ProjectGrid projects={specializations} columns={1}/>
</BaseLayout>